# Growzilla.xyz — Environment Configuration
# Copy to .env.local and fill in your values

# Backend API (EcomDash FastAPI)
ECOMDASH_API_URL=https://ecomdash-api.onrender.com
NEXT_PUBLIC_API_URL=https://ecomdash-api.onrender.com

# Admin API key (for server-side calls to backend: bootstrapOrg, shop management)
RENDER_API_KEY=your_admin_api_key

# Admin auth (for /admin dashboard)
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET=your_admin_hmac_secret

# User auth (for /setup account creation flow)
USER_SECRET=your_user_hmac_secret

# Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# AI keys (for quiz/tools — optional)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
